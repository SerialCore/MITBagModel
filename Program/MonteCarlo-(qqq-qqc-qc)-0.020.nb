Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"<<", "MITBagModel\\MITBagModel.m"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"SeedRandom", "[", "1000", "]"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "0"}], ",", 
   RowBox[{"i", "<", "100000"}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mc", "=", 
     RowBox[{"1.5", "+", 
      RowBox[{"0.3", "*", 
       RowBox[{"RandomReal", "[", "]"}]}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"b", "=", 
     RowBox[{"0.120", "+", 
      RowBox[{"0.12", "*", 
       RowBox[{"RandomReal", "[", "]"}]}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Z", "=", 
     RowBox[{"1.", "+", 
      RowBox[{"1.2", "*", 
       RowBox[{"RandomReal", "[", "]"}]}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"qqq", "=", 
     RowBox[{"MITBagModel`HadronFitting", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "0", ",", "3"}], "}"}], ",", "0", ",", 
       RowBox[{"{", 
        RowBox[{"4.884", ",", "mc", ",", "0.279", ",", "0", ",", 
         SuperscriptBox["b", "4"], ",", "Z"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"qc", "=", 
     RowBox[{"MITBagModel`HadronFitting", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", "0", ",", "1"}], "}"}], ",", "0", ",", 
       RowBox[{"{", 
        RowBox[{"4.884", ",", "mc", ",", "0.279", ",", "0", ",", 
         SuperscriptBox["b", "4"], ",", "Z"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"qqc", "=", 
     RowBox[{"MITBagModel`HadronFitting", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", "0", ",", "2"}], "}"}], ",", "0", ",", 
       RowBox[{"{", 
        RowBox[{"4.884", ",", "mc", ",", "0.279", ",", "0", ",", 
         SuperscriptBox["b", "4"], ",", "Z"}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"First", "[", "qqq", "]"}], "-", "1.1343"}], "]"}], "<", 
        "0.020"}], " ", "&&", " ", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"First", "[", "qc", "]"}], "-", "1.9732"}], "]"}], "<", 
        "0.020"}], " ", "&&", " ", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"First", "[", "qqc", "]"}], "-", "2.4442"}], "]"}], "<", 
        "0.020"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"First", "[", "qqq", "]"}], ",", 
          RowBox[{"First", "[", "qc", "]"}], ",", 
          RowBox[{"First", "[", "qqc", "]"}], ",", "mc", ",", "b", ",", "Z"}],
          "}"}], "]"}], ";", "\[IndentingNewLine]", "Continue"}]}], 
     "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "Input",
